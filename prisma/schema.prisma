// prisma/schema.prisma
datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"] // <--- AJOUTE CETTE LIGNE
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  password      String?
  image         String?      
  title         String?
  walletBalance Int          @default(1000)
  role          Role         @default(USER)
  createdAt     DateTime     @default(now())
  currentStreak Int          @default(0)
  bestStreak    Int          @default(0)
  nextBetMalus  Int          @default(0)
  lootboxes      Int            @default(0) // Nombre de caisses de contrebande à ouvrir
  lastDailyReset DateTime       @default(now()) // Pour savoir si on doit lui redonner des missions
  missions       DailyMission[] // <--- Le lien vers ses missions du jour
  brigadeId      String?
  brigade        Brigade?       @relation(fields: [brigadeId], references: [id])
  bets          Bet[]
  items         UserItem[]
  badges        Badge[]
  rackets       UserRacket[]
}

model Course {
  id                 String       @id @default(cuid())
  subject            String       
  professor          String       
  scheduledStartTime DateTime     
  actualArrivalTime  DateTime?    
  status             CourseStatus @default(OPEN)
  bets               Bet[]
  totalPot           Int          @default(0)
}

enum CourseStatus {
  OPEN      
  LOCKED    
  FINISHED  
}

model Bet {
  id           String   @id @default(cuid())
  userId       String
  courseId     String
  guessedTime  DateTime
  amount       Int      @default(100)
  pointsEarned Int?     @default(0)
  appliedItem  String?  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([userId, courseId])
}

model UserItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemType  String   // "VEST", "MAGNIFIER", "WARRANT"
  quantity  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, itemType])
}

model Badge {
  id          String   @id @default(cuid())
  type        String   // "SNIPER", "VETERAN", "MILLIONAIRE", "HOT_STREAK"
  unlockedAt  DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

enum Role {
  USER
  ADMIN
}

model UserRacket {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  racketType      String   // "KEBAB", "CHICHA", "NIGHTCLUB"
  lastCollectedAt DateTime @default(now()) // Heure de la dernière récolte
  createdAt       DateTime @default(now())

  @@unique([userId, racketType]) // Un agent ne peut posséder qu'une fois le même commerce
}

model DailyMission {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  actionType  String   // Ex: "PLACE_BETS", "USE_IGPN", "PLAY_SCELLES", "BUY_SHOP"
  description String   // Ex: "Dresser 2 PV au pif (Parier)"
  target      Int      // Ex: 2 (Le nombre de fois qu'il faut le faire)
  progress    Int      @default(0) // Où en est le joueur
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Brigade {
  id          String   @id @default(cuid())
  name        String   @unique
  bank        Int      @default(0) // L'argent total donné par les membres
  leaderId    String   // L'ID du créateur de la brigade
  createdAt   DateTime @default(now())

  members     User[]   // La liste des agents qui en font partie
}